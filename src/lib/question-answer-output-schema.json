{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": ["answer", "evidence"],
  "properties": {
    "answer": {
      "type": "string",
      "minLength": 1
    },
    "evidence": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
