{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status",
    "summary",
    "evidence",
    "filesTouched",
    "questions",
    "verification",
    "review",
    "taskProposals",
    "staffing"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["completed", "blocked", "needs_input", "retry_required"]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "evidence": {
      "type": "array",
      "items": { "type": "string" }
    },
    "filesTouched": {
      "type": "array",
      "items": { "type": "string" }
    },
    "questions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["question", "priority", "toRole"],
        "properties": {
          "question": { "type": "string", "minLength": 1 },
          "priority": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          },
          "toRole": {
            "type": "string",
            "enum": ["manager", "planner", "observer", "executor", "verifier", "reviewer"]
          }
        }
      }
    },
    "taskProposals": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "title",
          "objective",
          "role",
          "dependencies",
          "acceptanceChecks",
          "readRoots",
          "allowedFiles",
          "forbiddenFiles"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "objective": {
            "type": "string",
            "minLength": 1
          },
          "role": {
            "type": "string",
            "enum": ["manager", "planner", "observer", "executor", "verifier", "reviewer"]
          },
          "dependencies": {
            "type": "array",
            "items": { "type": "string" }
          },
          "acceptanceChecks": {
            "type": "array",
            "items": { "type": "string" }
          },
          "readRoots": {
            "type": "array",
            "items": { "type": "string" }
          },
          "allowedFiles": {
            "type": "array",
            "items": { "type": "string" }
          },
          "forbiddenFiles": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "staffing": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["role", "count", "rationale"],
        "properties": {
          "role": {
            "type": "string",
            "enum": ["manager", "planner", "observer", "executor", "verifier", "reviewer"]
          },
          "count": {
            "type": "integer",
            "minimum": 1
          },
          "rationale": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "verification": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["status", "evidence"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["pass", "fail", "unclear"]
        },
        "evidence": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "review": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["status", "summary", "findings"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["pass", "fail"]
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "findings": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["summary", "severity"],
            "properties": {
              "summary": {
                "type": "string",
                "minLength": 1
              },
              "severity": {
                "type": "string",
                "enum": ["low", "medium", "high"]
              }
            }
          }
        }
      }
    }
  }
}
